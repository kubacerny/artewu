---
import type { ImageMetadata } from 'astro';
import { imgSrc } from '../lib/img';

interface Props {
  href: string;
  title: string;
  description: string;
  date: Date;
  category: 'truhlarstvi' | 'software';
  cover?: string | ImageMetadata;
}

const { href, title, description, date, category, cover } = Astro.props;
const coverUrl = imgSrc(cover);

const categoryLabel = category === 'truhlarstvi' ? 'Truhlářství' : 'Software';
const formattedDate = new Intl.DateTimeFormat('cs-CZ', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(date);
---

<a
  href={href}
  class="group block bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-brand-100"
>
  {coverUrl && (
    <div class="aspect-[4/3] overflow-hidden bg-brand-100">
      <img
        src={coverUrl}
        alt={title}
        loading="lazy"
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      />
    </div>
  )}
  <div class="p-6">
    <div class="flex items-center gap-3 text-xs text-brand-600 mb-3">
      <span class="inline-block px-2 py-1 rounded-full bg-brand-100 text-brand-700 font-medium">
        {categoryLabel}
      </span>
      <time datetime={date.toISOString()}>{formattedDate}</time>
    </div>
    <h3 class="font-serif text-xl text-brand-900 group-hover:text-brand-600 transition-colors mb-2">
      {title}
    </h3>
    <p class="text-sm text-brand-700 leading-relaxed line-clamp-3">{description}</p>
  </div>
</a>
